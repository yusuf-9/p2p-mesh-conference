# ===========================================
# DEVELOPMENT ENVIRONMENT
# ===========================================

# Note: Most configuration is now hardcoded in docker-compose.yml
# for simplicity. This file is mainly for documentation and future
# customization if needed.

# Database Connection (for local websocket server)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mediaserver_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mediaserver2024

# JWT Secrets (for local websocket server)
JWT_SUPER_ADMIN_SECRET=dev-super-admin-secret
JWT_ADMIN_SECRET=dev-admin-secret
JWT_USER_SECRET=dev-user-secret
JWT_EXPIRES_IN=24h

# Server Configuration (for local websocket server)
NODE_ENV=development
SERVER_PORT=8080
CORS_ORIGIN=*
DEBUG=true
LOG_LEVEL=debug

# Application Limits
MAX_ROOMS=100
MAX_PARTICIPANTS_PER_ROOM=10 