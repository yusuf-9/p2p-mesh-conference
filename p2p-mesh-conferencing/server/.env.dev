# ===========================================
# P2P MESH DEVELOPMENT ENVIRONMENT
# ===========================================
# Environment variables for P2P mesh video conferencing development
# This file contains development-specific settings

# Database Connection (matches docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mediaserver_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mediaserver2024

# Redis Connection (matches docker-compose.yml with password from redis.conf)
REDIS_URL=redis://:mediaserver2024@localhost:6379

# JWT Secrets (for development - use different secrets in production!)
JWT_SUPER_ADMIN_SECRET=dev-super-admin-secret
JWT_ADMIN_SECRET=dev-admin-secret
JWT_USER_SECRET=dev-user-secret
JWT_EXPIRES_IN=24h

# Server Configuration
NODE_ENV=development
SERVER_PORT=3000
CORS_ORIGIN=*
DEBUG=true
LOG_LEVEL=debug

# Application Limits - P2P mesh optimized
MAX_ROOMS=100
MAX_PARTICIPANTS_PER_ROOM=6
# P2P mesh works best with fewer participants for optimal performance

# P2P Mesh Configuration
# WebSocket server configuration for P2P relay
WS_SERVER_PORT=3000
WS_PATH=/api/socket

# WebRTC Configuration for P2P mesh development
# STUN servers for NAT traversal in P2P connections
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# P2P Mesh Development Settings
P2P_CONNECTION_TIMEOUT=30000
P2P_ICE_GATHERING_TIMEOUT=10000
P2P_SIGNALING_TIMEOUT=15000

# Rate Limiting for development (more lenient)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Development WebRTC Settings
# Add TURN server for development testing if needed:
# WEBRTC_TURN_SERVER=turn:your-turn-server.com:3478
# WEBRTC_TURN_USERNAME=dev-username
# WEBRTC_TURN_PASSWORD=dev-password

# Removed SFU-specific configuration:
# - SFU_WS_URI (not applicable for P2P mesh architecture)
# - Janus Gateway settings
# - SFU media server configuration
