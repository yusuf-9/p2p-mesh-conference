# ===========================================
# DEVELOPMENT ENVIRONMENT
# ===========================================
# This file contains environment variables for running the server 
# locally in development mode with Docker Compose services

# Database Connection (matches docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mediaserver_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mediaserver2024

# Redis Connection (matches docker-compose.yml with password from redis.conf)
REDIS_URL=redis://:mediaserver2024@localhost:6379

# JWT Secrets (for development - use different secrets in production!)
JWT_SUPER_ADMIN_SECRET=dev-super-admin-secret
JWT_USER_SECRET=dev-user-secret
JWT_EXPIRES_IN=24h

# Server Configuration
NODE_ENV=development
SERVER_PORT=3000
CORS_ORIGIN=*
DEBUG=true
LOG_LEVEL=debug

# Application Limits
MAX_ROOMS=100
MAX_PARTICIPANTS_PER_ROOM=10

# SFU Configuration (Janus Gateway WebSocket URL for development)
SFU_WS_URI=ws://localhost:8188

# Coturn config
TURN_SECRET=dev_secret
TURN_SERVER_URL=localhost
TURN_SERVER_PORT=3478
